// YZC-0079: passing a value that does not satisfy the Node bound.
// g has abstract type Graph with Node #(label #(String)).
// City has no label() method, so it fails the bound check.

Graph: { Node #(label #(String)) }

City: { name String }

CityGraph: { Node: City }

describe #(g Graph, n g.Node) { print(n.label()) }

main: {
    g Graph = CityGraph()
    london: City(name: "London")
    describe(g, london)
}
