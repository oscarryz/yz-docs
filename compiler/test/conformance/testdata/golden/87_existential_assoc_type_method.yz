// YZC-0079: g.Node with abstract g is structurally equivalent to its bound.
// Any value satisfying Node #(label #(String)) is a valid g.Node,
// whether g is concrete (CityGraph) or abstract (Graph).

Graph: { Node #(label #(String)) }

City: {
    name String
    label #(String) = { name }
}

CityGraph: { Node: City }

describe #(g Graph, n g.Node) { print(n.label()) }

main: {
    cg: CityGraph()
    london: City(name: "London")
    describe(cg, london)

    g Graph = cg
    describe(g, london)
}
