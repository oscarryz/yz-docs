main: {
    a: 10.0
    b: 3.0

    print(a + b)
    print(a - b)
    print(a * b)
    print(a / b)
    print(-a)

    print(a == b)
    print(a != b)
    print(a < b)
    print(a > b)
    print(a <= b)
    print(a >= b)

    x: 3.14
    print(x.abs())
    print(x.pow(2.0))
    print(x.to_str())

    print(5.0 / 2.0)
}
