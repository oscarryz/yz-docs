// YZC-0072 — inline anonymous interface constraint in type params
// V #(method #(ReturnType)) declares V must implement an anonymous interface.

Animal: {
    name String
    describe #(String) = { name }
}

// Box constrains V with an inline anonymous interface — no named Describable needed.
Box: {
    V #( describe #(String) )
    value V
    desc #(String) {
        value.describe()
    }
}

main: {
    a : Animal(name: "Cat")
    b : Box(value: a)
    print(b.desc())
}
