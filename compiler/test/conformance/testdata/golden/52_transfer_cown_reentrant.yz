// Transfer pattern: BocWithSig with two cown-bearing params.
// Methods called on those params inside a conditional branch must be
// emitted as reentrant (sync) calls — not GoWait goroutines — so that
// balance updates take effect before the ScheduleMulti releases the cowns.
// Without the fix, a racing second transfer sees stale balances.

Account: {
    balance Int
    deposit #(amount Int) { balance = balance + amount }
    withdraw #(amount Int) { balance = balance - amount }
}

transfer #(src Account, dst Account, amount Int) {
    src.balance >= amount ? {
        src.withdraw(amount)
        dst.deposit(amount)
    }, {
        print("insufficient funds")
    }
}

main: {
    alice: Account(100)
    bob:   Account(0)
    transfer(alice, bob, 30)
    print(alice.balance)
    print(bob.balance)
}
